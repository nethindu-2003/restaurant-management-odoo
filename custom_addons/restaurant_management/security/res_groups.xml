<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define Module Category -->
    <record id="module_category_restaurant_management" model="ir.module.category">
        <field name="name">Restaurant Management</field>
        <field name="description">Helps manage reservations, tables, orders, and dashboard.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Define Privilege (for Odoo 19 group category assignment) -->
    <record id="res_groups_privilege_restaurant_management" model="res.groups.privilege">
        <field name="name">Restaurant Management</field>
        <field name="sequence">22</field>
        <field name="category_id" ref="base.module_category_sales"/>
    </record>

    <!-- Define Groups with privilege_id -->
    <record id="group_restaurant_staff" model="res.groups">
        <field name="name">Staff</field>
        <field name="privilege_id" ref="res_groups_privilege_restaurant_management"/>
        <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
    </record>

    <record id="group_restaurant_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="res_groups_privilege_restaurant_management"/>
        <field name="implied_ids" eval="[(4, ref('group_restaurant_staff')), (4, ref('point_of_sale.group_pos_manager'))]"/>
    </record>
</odoo>
