<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Table Form View to add Reservable option -->
    <record id="view_restaurant_table_form_inherit" model="ir.ui.view">
        <field name="name">restaurant.table.form.inherit</field>
        <field name="model">restaurant.table</field>
        <field name="inherit_id" ref="pos_restaurant.view_restaurant_table_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='seats']" position="after">
                <field name="is_reservable"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Floor Form View to add Reservable option to the nested table list -->
    <record id="view_restaurant_floor_form_inherit" model="ir.ui.view">
        <field name="name">restaurant.floor.form.inherit</field>
        <field name="model">restaurant.floor</field>
        <field name="inherit_id" ref="pos_restaurant.view_restaurant_floor_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='table_ids']/list/field[@name='seats']" position="after">
                <field name="is_reservable"/>
            </xpath>
        </field>
    </record>
</odoo>
